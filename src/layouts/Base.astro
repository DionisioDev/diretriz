---
import '../styles/global.css';
import Header from '../components/astro/Header.astro';
import Footer from '../components/astro/Footer.astro';
import { buildSeo, organizationJsonLd, type SeoInput } from '../lib/seo';
import type { Locale } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  path: string;
  ogImage?: string;
}

const { title, description, locale, path, ogImage } = Astro.props as Props;
const seo = buildSeo({ title, description, locale, path, ogImage } satisfies SeoInput);
---

<!doctype html>
<html lang={seo.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />

    {seo.alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}

    <meta property="og:type" content="website" />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={seo.ogImage} />
    <meta property="og:locale" content={seo.locale.replace('-', '_')} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.ogImage} />

    <meta name="theme-color" content="#FFFFFF" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd())} />
  </head>
  <body>
    <a href="#main" class="skip-link">Pular para o conteúdo</a>

    <Header locale={locale} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />

    <script>
      // Reveal-on-scroll: usa scroll + getBoundingClientRect (mais robusto que IntersectionObserver
      // em alguns contextos de iframe/embed). Adiciona .in quando o elemento entra a 92% do viewport.
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (reduceMotion) {
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
      } else {
        const check = () => {
          const vh = window.innerHeight || document.documentElement.clientHeight;
          const trigger = vh * 0.92;
          const els = document.querySelectorAll('.reveal:not(.in)');
          els.forEach((el) => {
            const r = el.getBoundingClientRect();
            if (r.top < trigger && r.bottom > 0) {
              el.classList.add('in');
            }
          });
        };

        let raf = 0;
        const onScroll = () => {
          if (raf) return;
          raf = requestAnimationFrame(() => {
            raf = 0;
            check();
          });
        };

        check();
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll);
        document.body.addEventListener('scroll', onScroll, { passive: true });

        // Re-check após montagens atrasadas (preloader, typewriter, ilhas React)
        setTimeout(check, 400);
        setTimeout(check, 1500);
        setTimeout(check, 3000);
      }
    </script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    top: -100px;
    left: var(--space-md);
    z-index: var(--z-toast);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-primary);
    color: #fff;
    border-radius: var(--radius-md);
    font-weight: var(--weight-medium);
    transition: top var(--motion-fast) var(--ease);
  }
  .skip-link:focus-visible {
    top: var(--space-md);
  }

  main {
    min-height: 100dvh;
  }
</style>
