---
import Base from '../layouts/Base.astro';

const locale = 'pt' as const;
---

<Base
  locale={locale}
  path="/servicos"
  title="Serviços — Diretriz Tecnologia"
  description="Produtos sob medida, automação de fluxos internos, integração de IA e consultoria técnica."
>
  <section class="placeholder">
    <p class="kicker mono">/ Serviços</p>
    <h1>Em construção.</h1>
    <p class="lead">Os 4 pilares de oferta serão detalhados aqui na v1: produtos sob medida, automação, IA e consultoria.</p>
  </section>
</Base>

<style>
  .placeholder {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-4xl) var(--container-padding) var(--space-2xl);
  }
  .kicker {
    font-size: var(--size-xs);
    color: var(--color-accent);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }
  h1 {
    font-size: var(--size-2xl);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-md);
  }
  .lead {
    color: var(--color-text-muted);
    max-width: 60ch;
  }
</style>
