---
import Base from '../layouts/Base.astro';
import { getContent } from '../lib/i18n';

const locale = 'pt' as const;
const c = getContent(locale);
---

<Base
  locale={locale}
  path="/contato"
  title="Contato — Diretriz Tecnologia"
  description="Conte seu problema. Respondemos em até 1 dia útil."
>
  <section class="stub section-pad">
    <div class="container">
      <div class="section-label">{c.nav.contact}</div>
      <h1 class="stub__title">Vamos construir juntos.</h1>
      <p class="stub__lead">
        O formulário interativo entra em uma próxima iteração. Por enquanto, escreva direto para nós:
      </p>
      <a class="stub__email btn btn--primary" href="mailto:diretriztecnologia@gmail.com">
        diretriztecnologia@gmail.com
        <svg class="btn-arrow" viewBox="0 0 14 14" aria-hidden="true">
          <path d="M2 12 L12 2 M5 2 L12 2 L12 9" stroke="currentColor" stroke-width="1.5" fill="none" />
        </svg>
      </a>
    </div>
  </section>
</Base>

<style>
  .stub {
    padding-top: clamp(140px, 16vw, 220px);
  }
  .stub__title {
    font-size: clamp(2rem, 1rem + 3vw, 3.5rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.05;
    margin: 0 0 24px 0;
    max-width: 22ch;
    text-wrap: balance;
  }
  .stub__lead {
    color: var(--color-text-muted);
    max-width: 56ch;
    font-size: 1.0625rem;
    margin-bottom: 32px;
  }
  .stub__email {
    /* compõe com .btn .btn--primary do global.css */
  }
</style>
