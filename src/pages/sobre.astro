---
import Base from '../layouts/Base.astro';
import { getContent } from '../lib/i18n';

const locale = 'pt' as const;
const c = getContent(locale);
---

<Base
  locale={locale}
  path="/sobre"
  title="Sobre — Diretriz Tecnologia"
  description="Quem somos, como trabalhamos e por que entregamos rápido sem sacrificar a qualidade."
>
  <section class="stub section-pad">
    <div class="container">
      <div class="section-label">{c.stub.label}</div>
      <h1 class="stub__title">{c.stub.title}</h1>
      <p class="stub__lead">
        {c.stub.leadBefore} <a href="mailto:diretriztecnologia@gmail.com">diretriztecnologia@gmail.com</a>.
      </p>
    </div>
  </section>
</Base>

<style>
  .stub {
    padding-top: clamp(140px, 16vw, 220px);
  }
  .stub__title {
    font-size: clamp(2rem, 1rem + 3vw, 3.5rem);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.05;
    margin: 0 0 24px 0;
    max-width: 22ch;
    text-wrap: balance;
  }
  .stub__lead {
    color: var(--color-text-muted);
    max-width: 56ch;
    font-size: 1.0625rem;
  }
  .stub__lead a {
    color: var(--color-primary);
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    font-weight: 500;
  }
</style>
