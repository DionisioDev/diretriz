---
import { t, getLocalizedPath, getAlternateLocale, localeShort, type Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const altLocale = getAlternateLocale(locale);
const altPath = getLocalizedPath('home', altLocale);
---

<header class="header">
  <div class="inner">
    <a href={getLocalizedPath('home', locale)} class="brand" aria-label="Diretriz Tecnologia">
      <span class="brand-mark" aria-hidden="true">
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M2 16 L30 4 L18 16 L30 28 Z" fill="currentColor" opacity="0.9" />
          <path d="M2 16 L18 16 L11 22 Z" fill="currentColor" opacity="0.5" />
        </svg>
      </span>
      <span class="brand-text">
        <span class="brand-name">Diretriz</span>
        <span class="brand-sub">tecnologia</span>
      </span>
    </a>

    <nav class="nav" aria-label="Principal">
      <a href={getLocalizedPath('about', locale)}>{t('nav.about', locale)}</a>
      <a href={getLocalizedPath('services', locale)}>{t('nav.services', locale)}</a>
      <a href={getLocalizedPath('contact', locale)} class="cta">{t('cta.contact', locale)}</a>
      <a href={altPath} class="lang" aria-label={`Switch to ${altLocale.toUpperCase()}`}>
        {localeShort[altLocale]}
      </a>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    backdrop-filter: blur(16px);
    background: rgba(10, 22, 40, 0.6);
    border-bottom: 1px solid var(--color-border);
  }

  .inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-md) var(--container-padding);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
  }

  .brand-mark {
    width: 28px;
    height: 28px;
    color: var(--color-primary-bright);
    display: inline-flex;
  }

  .brand-text {
    display: inline-flex;
    flex-direction: column;
    line-height: 1;
  }

  .brand-name {
    font-size: var(--size-md);
  }

  .brand-sub {
    font-size: var(--size-xs);
    color: var(--color-text-muted);
    font-weight: var(--weight-regular);
    margin-top: 2px;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .nav a {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    transition: color var(--motion-fast) var(--ease-out);
  }

  .nav a:hover {
    color: var(--color-text);
  }

  .nav .cta {
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-full);
    background: var(--gradient-brand);
    color: var(--color-text);
    font-weight: var(--weight-medium);
    transition: transform var(--motion-fast) var(--ease-out), box-shadow var(--motion-fast) var(--ease-out);
  }

  .nav .cta:hover {
    color: var(--color-text);
    transform: translateY(-1px);
    box-shadow: var(--shadow-glow);
  }

  .nav .lang {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    letter-spacing: var(--tracking-widest);
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
  }

  @media (max-width: 720px) {
    .inner {
      gap: var(--space-md);
    }
    .nav {
      gap: var(--space-md);
    }
    .nav a:not(.cta):not(.lang) {
      display: none;
    }
  }
</style>
