---
import BrandMark from './BrandMark.astro';
import { getContent, getSectionAnchor, getLocalizedPath, localeShort, type Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const c = getContent(locale);
const homePath = getLocalizedPath('home', locale);
---

<header class="nav" id="site-nav">
  <a href={homePath} class="nav__brand" aria-label="Diretriz Tecnologia">
    <BrandMark size={30} />
    <span class="nav__brand-text">
      <span class="nav__brand-name">Diretriz</span>
      <small>tecnologia</small>
    </span>
  </a>

  <nav class="nav__links" aria-label="Principal">
    <a class="nav__link" data-section="sobre" href={getSectionAnchor('sobre', locale)}>{c.nav.about}</a>
    <a class="nav__link" data-section="servicos" href={getSectionAnchor('servicos', locale)}>{c.nav.services}</a>
    <a class="nav__link" data-section="processo" href={getSectionAnchor('processo', locale)}>{c.nav.process}</a>
    <a class="nav__link" data-section="contato" href={getSectionAnchor('contato', locale)}>{c.nav.contact}</a>
  </nav>

  <div class="nav__right">
    <div class="nav__lang" role="group" aria-label={c.langSwitch.label}>
      <a class:list={['nav__lang-link', locale === 'pt' && 'active']} href="/" lang="pt">
        <span>{localeShort.pt}</span>
        {locale === 'pt' && (
          <svg class="nav__lang-caret" viewBox="0 0 10 6" aria-hidden="true">
            <path d="M1 1.25 5 4.75 9 1.25" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        )}
      </a>
      <span class="nav__lang-sep" aria-hidden="true">|</span>
      <a class:list={['nav__lang-link', locale === 'en' && 'active']} href="/en/" lang="en">
        <span>{localeShort.en}</span>
        {locale === 'en' && (
          <svg class="nav__lang-caret" viewBox="0 0 10 6" aria-hidden="true">
            <path d="M1 1.25 5 4.75 9 1.25" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        )}
      </a>
    </div>
    <a href={getSectionAnchor('contato', locale)} class="nav__cta">
      {c.nav.cta}
      <svg class="nav__cta-arrow" viewBox="0 0 12 12" aria-hidden="true">
        <path d="M2 10 L10 2 M4 2 L10 2 L10 8" stroke="currentColor" stroke-width="1.5" fill="none" />
      </svg>
    </a>
    <button
      type="button"
      class="nav__toggle"
      id="nav-toggle"
      aria-label={c.nav.cta}
      aria-controls="nav-mobile"
      aria-expanded="false"
    >
      <span class="material-symbols-outlined nav__toggle-icon nav__toggle-icon--open" aria-hidden="true">menu</span>
      <span class="material-symbols-outlined nav__toggle-icon nav__toggle-icon--close" aria-hidden="true">close</span>
    </button>
  </div>
</header>

<div class="nav__mobile" id="nav-mobile" hidden>
  <nav class="nav__mobile-links" aria-label="Principal (mobile)">
    <a class="nav__mobile-link" href={getSectionAnchor('sobre', locale)}>{c.nav.about}</a>
    <a class="nav__mobile-link" href={getSectionAnchor('servicos', locale)}>{c.nav.services}</a>
    <a class="nav__mobile-link" href={getSectionAnchor('processo', locale)}>{c.nav.process}</a>
    <a class="nav__mobile-link" href={getSectionAnchor('contato', locale)}>{c.nav.contact}</a>
  </nav>
  <a href={getSectionAnchor('contato', locale)} class="nav__mobile-cta">
    {c.nav.cta}
    <svg viewBox="0 0 12 12" aria-hidden="true">
      <path d="M2 10 L10 2 M4 2 L10 2 L10 8" stroke="currentColor" stroke-width="1.5" fill="none" />
    </svg>
  </a>
</div>

<script>
  // ---- Estado do header: sombra ao rolar + link ativo (scroll-spy) ----
  const nav = document.getElementById('site-nav');
  const spyLinks = Array.from(document.querySelectorAll<HTMLElement>('.nav__link[data-section]'));
  const sections = spyLinks
    .map((l) => document.getElementById(l.dataset.section || ''))
    .filter((el): el is HTMLElement => el !== null);

  const updateNav = () => {
    if (nav) nav.classList.toggle('scrolled', window.scrollY > 24);

    if (sections.length) {
      const offset = 140; // altura aproximada do header flutuante + folga
      let currentId = sections[0].id;
      for (const sec of sections) {
        if (sec.getBoundingClientRect().top <= offset) currentId = sec.id;
      }
      spyLinks.forEach((l) => l.classList.toggle('active', l.dataset.section === currentId));
    }
  };

  let rafId = 0;
  const onScroll = () => {
    if (rafId) return;
    rafId = requestAnimationFrame(() => {
      rafId = 0;
      updateNav();
    });
  };

  updateNav();
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll);

  // ---- Menu mobile (hambúrguer) ----
  const toggle = document.getElementById('nav-toggle');
  const panel = document.getElementById('nav-mobile');
  if (toggle && panel) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      document.body.classList.toggle('nav-open', open);
      if (open) {
        panel.hidden = false;
        // força reflow para a transição rodar a partir do estado hidden
        void panel.offsetHeight;
        panel.classList.add('is-open');
      } else {
        panel.classList.remove('is-open');
        const done = () => {
          if (toggle.getAttribute('aria-expanded') === 'false') panel.hidden = true;
          panel.removeEventListener('transitionend', done);
        };
        panel.addEventListener('transitionend', done);
      }
    };

    toggle.addEventListener('click', () => {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });

    // Fecha ao clicar num link ou apertar Esc
    panel.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') setOpen(false);
    });
    // Fecha ao tocar/clicar fora do painel (mobile)
    document.addEventListener('click', (e) => {
      if (toggle.getAttribute('aria-expanded') !== 'true') return;
      const target = e.target as Node;
      if (!panel.contains(target) && !toggle.contains(target)) setOpen(false);
    });
    // Fecha se a tela voltar pro desktop
    window.matchMedia('(min-width: 981px)').addEventListener('change', (e) => {
      if (e.matches) setOpen(false);
    });
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 14px;
    left: 0;
    right: 0;
    margin-inline: auto;
    width: min(calc(100% - var(--gutter) * 2), var(--container-max));
    z-index: var(--z-header);
    padding: 11px 14px 11px 22px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 16px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.4s var(--ease), border-color 0.4s var(--ease), background 0.4s var(--ease);
  }
  .nav.scrolled {
    box-shadow: var(--shadow-md);
    border-color: var(--color-border-strong);
  }

  .nav__brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--color-text);
    justify-self: start;
  }
  .nav__brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .nav__brand-name {
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .nav__brand small {
    font-family: var(--font-sans);
    font-size: 0.66rem;
    color: var(--color-primary);
    font-weight: 500;
    letter-spacing: 0.04em;
    margin-top: 3px;
  }

  .nav__links {
    display: flex;
    gap: 30px;
    align-items: center;
    justify-self: center;
  }
  .nav__link {
    position: relative;
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    transition: color 0.3s var(--ease);
    font-weight: 400;
    padding-bottom: 4px;
  }
  .nav__link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -6px;
    height: 2px;
    border-radius: 2px;
    background: var(--color-primary);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform var(--motion-fast) var(--ease);
  }
  .nav__link:hover {
    color: var(--color-text);
  }
  .nav__link.active {
    color: var(--color-text);
  }
  .nav__link.active::after {
    transform: scaleX(1);
  }

  .nav__right {
    display: flex;
    align-items: center;
    gap: 18px;
    justify-self: end;
  }

  .nav__lang {
    display: flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: 0.05em;
    color: var(--color-text-dim);
    gap: 7px;
  }
  .nav__lang-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color 0.3s;
    font-weight: 500;
  }
  .nav__lang-link.active {
    color: var(--color-text);
  }
  .nav__lang-link:hover {
    color: var(--color-text);
  }
  .nav__lang-sep {
    color: var(--color-text-faint);
  }
  .nav__lang-caret {
    width: 8px;
    height: 5px;
    margin-top: 1px;
    color: var(--color-text-dim);
  }

  .nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 9px 16px;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    color: #fff;
    font-size: var(--fs-small);
    font-weight: 500;
    transition: background 0.3s, transform 0.3s var(--ease), box-shadow 0.3s;
    box-shadow: 0 1px 2px rgba(37, 99, 235, 0.18), 0 0 0 1px rgba(37, 99, 235, 0.08);
  }
  .nav__cta:hover {
    background: var(--color-primary-bright);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(37, 99, 235, 0.25), 0 0 0 1px rgba(37, 99, 235, 0.14);
  }
  .nav__cta-arrow {
    width: 12px;
    height: 12px;
    transition: transform 0.3s var(--ease);
  }
  .nav__cta:hover .nav__cta-arrow {
    transform: translate(2px, -2px);
  }

  /* ---- Botão hambúrguer (oculto no desktop) ---- */
  .nav__toggle {
    display: none;
    width: 42px;
    height: 42px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-elevated);
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-text);
    transition: border-color var(--motion-fast) var(--ease), background var(--motion-fast);
  }
  .nav__toggle-icon {
    font-size: 24px;
  }
  /* Fechado mostra "menu"; ao abrir (body.nav-open) troca para "close". */
  .nav__toggle-icon--close {
    display: none;
  }
  :global(body.nav-open) .nav__toggle-icon--open {
    display: none;
  }
  :global(body.nav-open) .nav__toggle-icon--close {
    display: inline-block;
  }

  /* ---- Painel mobile ---- */
  .nav__mobile {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: calc(var(--z-header) - 1);
    padding: 84px var(--gutter) 28px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(22px) saturate(160%);
    -webkit-backdrop-filter: blur(22px) saturate(160%);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 24px 48px -24px rgba(11, 18, 32, 0.18);
    display: flex;
    flex-direction: column;
    gap: 8px;
    transform: translateY(-12px);
    opacity: 0;
    transition: transform var(--motion-base) var(--ease), opacity var(--motion-base) var(--ease);
  }
  .nav__mobile.is-open {
    transform: translateY(0);
    opacity: 1;
  }
  .nav__mobile-links {
    display: flex;
    flex-direction: column;
  }
  .nav__mobile-link {
    padding: 14px 4px;
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    transition: color var(--motion-fast) var(--ease);
  }
  .nav__mobile-link:hover {
    color: var(--color-primary);
  }
  .nav__mobile-cta {
    margin-top: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 22px;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    color: #fff;
    font-size: var(--fs-small);
    font-weight: 500;
    box-shadow: 0 1px 2px rgba(37, 99, 235, 0.18), 0 8px 24px rgba(37, 99, 235, 0.18);
  }
  .nav__mobile-cta svg {
    width: 12px;
    height: 12px;
  }

  @media (max-width: 980px) {
    /* nav__links some no mobile, deixando só brand + nav__right como grid items.
       Sem reduzir as colunas, o auto-placement jogaria o nav__right para a coluna
       do meio (centro). Com 1fr auto, brand fica à esquerda e nav__right cola no
       canto direito. */
    .nav {
      grid-template-columns: 1fr auto;
    }
    .nav__links {
      display: none;
    }
    .nav__toggle {
      display: inline-flex;
    }
    /* No mobile o CTA compacto vira o do menu; mantém só lang + hambúrguer no topo */
    .nav__right > .nav__cta {
      display: none;
    }
  }

  @media (min-width: 981px) {
    .nav__mobile {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav__mobile,
    .nav__link::after {
      transition: none;
    }
  }
</style>
