---
import BrandMark from './BrandMark.astro';
import { getContent, getSectionAnchor, getLocalizedPath, localeShort, type Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const c = getContent(locale);
const homePath = getLocalizedPath('home', locale);
---

<header class="nav" id="site-nav">
  <a href={homePath} class="nav__brand" aria-label="Diretriz Tecnologia">
    <BrandMark size={30} />
    <span class="nav__brand-text">
      <span class="nav__brand-name">Diretriz</span>
      <small>tecnologia</small>
    </span>
  </a>

  <nav class="nav__links" aria-label="Principal">
    <a class="nav__link" href={getSectionAnchor('sobre', locale)}>{c.nav.about}</a>
    <a class="nav__link" href={getSectionAnchor('servicos', locale)}>{c.nav.services}</a>
    <a class="nav__link" href={getSectionAnchor('processo', locale)}>{c.nav.process}</a>
    <a class="nav__link" href={getSectionAnchor('contato', locale)}>{c.nav.contact}</a>
  </nav>

  <div class="nav__right">
    <div class="nav__lang" role="group" aria-label={c.langSwitch.label}>
      <a class:list={['nav__lang-link', locale === 'pt' && 'active']} href="/" lang="pt">{localeShort.pt}</a>
      <span aria-hidden="true">|</span>
      <a class:list={['nav__lang-link', locale === 'en' && 'active']} href="/en/" lang="en">{localeShort.en}</a>
    </div>
    <a href={getSectionAnchor('contato', locale)} class="nav__cta">
      {c.nav.cta}
      <svg class="nav__cta-arrow" viewBox="0 0 12 12" aria-hidden="true">
        <path d="M2 10 L10 2 M4 2 L10 2 L10 8" stroke="currentColor" stroke-width="1.5" fill="none" />
      </svg>
    </a>
    <button
      type="button"
      class="nav__toggle"
      id="nav-toggle"
      aria-label={c.nav.cta}
      aria-controls="nav-mobile"
      aria-expanded="false"
    >
      <span class="nav__toggle-bar"></span>
      <span class="nav__toggle-bar"></span>
      <span class="nav__toggle-bar"></span>
    </button>
  </div>
</header>

<div class="nav__mobile" id="nav-mobile" hidden>
  <nav class="nav__mobile-links" aria-label="Principal (mobile)">
    <a class="nav__mobile-link" href={getSectionAnchor('sobre', locale)}>{c.nav.about}</a>
    <a class="nav__mobile-link" href={getSectionAnchor('servicos', locale)}>{c.nav.services}</a>
    <a class="nav__mobile-link" href={getSectionAnchor('processo', locale)}>{c.nav.process}</a>
    <a class="nav__mobile-link" href={getSectionAnchor('contato', locale)}>{c.nav.contact}</a>
  </nav>
  <a href={getSectionAnchor('contato', locale)} class="nav__mobile-cta">
    {c.nav.cta}
    <svg viewBox="0 0 12 12" aria-hidden="true">
      <path d="M2 10 L10 2 M4 2 L10 2 L10 8" stroke="currentColor" stroke-width="1.5" fill="none" />
    </svg>
  </a>
</div>

<script>
  const nav = document.getElementById('site-nav');
  if (nav) {
    const onScroll = () => {
      if (window.scrollY > 24) nav.classList.add('scrolled');
      else nav.classList.remove('scrolled');
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // ---- Menu mobile (hambúrguer) ----
  const toggle = document.getElementById('nav-toggle');
  const panel = document.getElementById('nav-mobile');
  if (toggle && panel) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      document.body.classList.toggle('nav-open', open);
      if (open) {
        panel.hidden = false;
        // força reflow para a transição rodar a partir do estado hidden
        void panel.offsetHeight;
        panel.classList.add('is-open');
      } else {
        panel.classList.remove('is-open');
        const done = () => {
          if (toggle.getAttribute('aria-expanded') === 'false') panel.hidden = true;
          panel.removeEventListener('transitionend', done);
        };
        panel.addEventListener('transitionend', done);
      }
    };

    toggle.addEventListener('click', () => {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });

    // Fecha ao clicar num link ou apertar Esc
    panel.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') setOpen(false);
    });
    // Fecha se a tela voltar pro desktop
    window.matchMedia('(min-width: 981px)').addEventListener('change', (e) => {
      if (e.matches) setOpen(false);
    });
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    padding: 18px var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: background 0.4s var(--ease), backdrop-filter 0.4s, border-color 0.4s;
    border-bottom: 1px solid transparent;
  }

  .nav.scrolled {
    background: rgba(250, 251, 253, 0.78);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border-bottom-color: var(--color-border);
  }

  .nav__brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--color-text);
  }
  .nav__brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .nav__brand-name {
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .nav__brand small {
    font-family: var(--font-sans);
    font-size: 0.66rem;
    color: var(--color-primary);
    font-weight: 500;
    letter-spacing: 0.04em;
    margin-top: 3px;
  }

  .nav__links {
    display: flex;
    gap: 34px;
    align-items: center;
  }
  .nav__link {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    transition: color 0.3s var(--ease);
    font-weight: 400;
  }
  .nav__link:hover {
    color: var(--color-text);
  }

  .nav__right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .nav__lang {
    display: flex;
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: 0.05em;
    color: var(--color-text-dim);
    gap: 6px;
  }
  .nav__lang-link {
    transition: color 0.3s;
    font-weight: 500;
  }
  .nav__lang-link.active {
    color: var(--color-text);
  }
  .nav__lang span {
    color: var(--color-text-faint);
  }

  .nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 9px 16px;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    color: #fff;
    font-size: var(--fs-small);
    font-weight: 500;
    transition: background 0.3s, transform 0.3s var(--ease), box-shadow 0.3s;
    box-shadow: 0 1px 2px rgba(37, 99, 235, 0.18), 0 0 0 1px rgba(37, 99, 235, 0.08);
  }
  .nav__cta:hover {
    background: var(--color-primary-bright);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(37, 99, 235, 0.25), 0 0 0 1px rgba(37, 99, 235, 0.14);
  }
  .nav__cta-arrow {
    width: 12px;
    height: 12px;
    transition: transform 0.3s var(--ease);
  }
  .nav__cta:hover .nav__cta-arrow {
    transform: translate(2px, -2px);
  }

  /* ---- Botão hambúrguer (oculto no desktop) ---- */
  .nav__toggle {
    display: none;
    width: 42px;
    height: 42px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-elevated);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    transition: border-color var(--motion-fast) var(--ease), background var(--motion-fast);
  }
  .nav__toggle-bar {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform var(--motion-fast) var(--ease), opacity var(--motion-fast) var(--ease);
  }
  :global(body.nav-open) .nav__toggle-bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  :global(body.nav-open) .nav__toggle-bar:nth-child(2) {
    opacity: 0;
  }
  :global(body.nav-open) .nav__toggle-bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ---- Painel mobile ---- */
  .nav__mobile {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: calc(var(--z-header) - 1);
    padding: 84px var(--gutter) 28px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(22px) saturate(160%);
    -webkit-backdrop-filter: blur(22px) saturate(160%);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 24px 48px -24px rgba(11, 18, 32, 0.18);
    display: flex;
    flex-direction: column;
    gap: 8px;
    transform: translateY(-12px);
    opacity: 0;
    transition: transform var(--motion-base) var(--ease), opacity var(--motion-base) var(--ease);
  }
  .nav__mobile.is-open {
    transform: translateY(0);
    opacity: 1;
  }
  .nav__mobile-links {
    display: flex;
    flex-direction: column;
  }
  .nav__mobile-link {
    padding: 14px 4px;
    font-size: 1.125rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    transition: color var(--motion-fast) var(--ease);
  }
  .nav__mobile-link:hover {
    color: var(--color-primary);
  }
  .nav__mobile-cta {
    margin-top: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 22px;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    color: #fff;
    font-size: var(--fs-small);
    font-weight: 500;
    box-shadow: 0 1px 2px rgba(37, 99, 235, 0.18), 0 8px 24px rgba(37, 99, 235, 0.18);
  }
  .nav__mobile-cta svg {
    width: 12px;
    height: 12px;
  }

  @media (max-width: 980px) {
    .nav__links {
      display: none;
    }
    .nav__toggle {
      display: inline-flex;
    }
    /* No mobile o CTA compacto vira o do menu; mantém só lang + hambúrguer no topo */
    .nav__right > .nav__cta {
      display: none;
    }
  }

  @media (min-width: 981px) {
    .nav__mobile {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav__mobile,
    .nav__toggle-bar {
      transition: none;
    }
  }
</style>
