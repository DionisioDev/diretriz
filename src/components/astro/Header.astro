---
import BrandMark from './BrandMark.astro';
import { getContent, getSectionAnchor, getLocalizedPath, localeShort, type Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const c = getContent(locale);
const homePath = getLocalizedPath('home', locale);
---

<header class="nav" id="site-nav">
  <a href={homePath} class="nav__brand" aria-label="Diretriz Tecnologia">
    <BrandMark />
    Diretriz <small>tecnologia</small>
  </a>

  <nav class="nav__links" aria-label="Principal">
    <a class="nav__link" href={getSectionAnchor('sobre', locale)}>{c.nav.about}</a>
    <a class="nav__link" href={getSectionAnchor('servicos', locale)}>{c.nav.services}</a>
    <a class="nav__link" href={getSectionAnchor('processo', locale)}>{c.nav.process}</a>
    <a class="nav__link" href={getSectionAnchor('contato', locale)}>{c.nav.contact}</a>
  </nav>

  <div class="nav__right">
    <div class="nav__lang" role="group" aria-label={c.langSwitch.label}>
      <a class:list={['nav__lang-link', locale === 'pt' && 'active']} href="/" lang="pt">{localeShort.pt}</a>
      <span aria-hidden="true">|</span>
      <a class:list={['nav__lang-link', locale === 'en' && 'active']} href="/en/" lang="en">{localeShort.en}</a>
    </div>
    <a href={getSectionAnchor('contato', locale)} class="nav__cta">
      {c.nav.cta}
      <svg class="nav__cta-arrow" viewBox="0 0 12 12" aria-hidden="true">
        <path d="M2 10 L10 2 M4 2 L10 2 L10 8" stroke="currentColor" stroke-width="1.5" fill="none" />
      </svg>
    </a>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav');
  if (nav) {
    const onScroll = () => {
      if (window.scrollY > 24) nav.classList.add('scrolled');
      else nav.classList.remove('scrolled');
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    padding: 18px var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: background 0.4s var(--ease), backdrop-filter 0.4s, border-color 0.4s;
    border-bottom: 1px solid transparent;
  }

  .nav.scrolled {
    background: rgba(250, 251, 253, 0.78);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border-bottom-color: var(--color-border);
  }

  .nav__brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--color-text);
  }
  .nav__brand small {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: var(--color-primary);
    font-weight: 500;
    margin-left: 2px;
    letter-spacing: 0.01em;
  }

  .nav__links {
    display: flex;
    gap: 34px;
    align-items: center;
  }
  .nav__link {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    transition: color 0.3s var(--ease);
    font-weight: 400;
  }
  .nav__link:hover {
    color: var(--color-text);
  }

  .nav__right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .nav__lang {
    display: flex;
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    letter-spacing: 0.05em;
    color: var(--color-text-dim);
    gap: 6px;
  }
  .nav__lang-link {
    transition: color 0.3s;
    font-weight: 500;
  }
  .nav__lang-link.active {
    color: var(--color-text);
  }
  .nav__lang span {
    color: var(--color-text-faint);
  }

  .nav__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 9px 16px;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    color: #fff;
    font-size: var(--fs-small);
    font-weight: 500;
    transition: background 0.3s, transform 0.3s var(--ease), box-shadow 0.3s;
    box-shadow: 0 1px 2px rgba(37, 99, 235, 0.18), 0 0 0 1px rgba(37, 99, 235, 0.08);
  }
  .nav__cta:hover {
    background: var(--color-primary-bright);
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 6px 18px rgba(37, 99, 235, 0.25), 0 0 0 1px rgba(37, 99, 235, 0.14);
  }
  .nav__cta-arrow {
    width: 12px;
    height: 12px;
    transition: transform 0.3s var(--ease);
  }
  .nav__cta:hover .nav__cta-arrow {
    transform: translate(2px, -2px);
  }

  @media (max-width: 980px) {
    .nav__links {
      display: none;
    }
  }
</style>
