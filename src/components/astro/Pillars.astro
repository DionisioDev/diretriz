---
import { getContent, type Locale } from '../../lib/i18n';
import { sectionIcons } from '../../lib/icons';
import SectionBadge from './SectionBadge.astro';
import SectionDecor from './SectionDecor.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const c = getContent(locale);
---

<section class="section-pad section-tint pillars" id="servicos" data-screen-label="03 Pilares">
  <SectionDecor variant={3} />

  <div class="container">
    <div class="pillars__head">
      <SectionBadge
        label={c.pillars.label}
        icon={sectionIcons.services}
        align="center"
        class="reveal reveal-fade"
      />
      <h2 class="section-title pillars__title reveal reveal-up reveal-d1">
        {c.pillars.titleStart}<span class="blue">{c.pillars.titleAccent}</span>{c.pillars.titleEnd}
      </h2>
      <p class="pillars__intro reveal reveal-up reveal-d2">{c.pillars.intro}</p>
    </div>

    <div class="pillars__grid">
      {c.pillars.items.map((p, i) => (
        <article class:list={['pillar', 'reveal', 'reveal-up', `reveal-d${i + 1}`, p.featured && 'featured']}>
          <div class="pillar__num">{p.num}</div>

          <div class="pillar__icon-box">
            <div class="pillar__icon">
              {p.num === '01' && (
                <svg viewBox="0 0 36 36" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
                  <path d="M18 4 L31 11 L31 25 L18 32 L5 25 L5 11 Z" />
                  <path d="M18 4 L18 18 L5 11" />
                  <path d="M18 18 L31 11" />
                  <path d="M18 18 L18 32" />
                </svg>
              )}
              {p.num === '02' && (
                <svg viewBox="0 0 36 36" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M19 4 L9 20 L17 20 L15 32 L27 16 L19 16 Z" />
                </svg>
              )}
              {p.num === '03' && (
                <svg viewBox="0 0 36 36" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="13" cy="13" r="4" />
                  <circle cx="25" cy="13" r="4" />
                  <path d="M5 28 C5 23 9 20 13 20 C17 20 21 23 21 28" />
                  <path d="M17 28 C17 23 21 20 25 20 C29 20 33 23 33 28" />
                </svg>
              )}
            </div>
          </div>

          <h3 class="pillar__title">{p.title}</h3>
          <p class="pillar__desc">{p.desc}</p>

          <hr class="pillar__divider" />

          <ul class="pillar__bullets">
            {p.bullets.map((b) => (
              <li>
                <svg class="pillar__check" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.2" opacity="0.35" />
                  <path d="M5.5 9 L8 11.5 L12.5 6.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <span>{b}</span>
              </li>
            ))}
          </ul>

          <a class="pillar__cta" href="#contato">
            <span>{p.cta}</span>
            <svg viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 10 L10 2 M4 2 L10 2 L10 8" stroke="currentColor" stroke-width="1.5" />
            </svg>
          </a>
        </article>
      ))}
    </div>

    <div class="pillars__banner reveal reveal-up reveal-d4">
      <div class="pillars__banner-icon" aria-hidden="true">
        <svg viewBox="0 0 28 28" fill="none">
          <path d="M5 8 C5 6.3 6.3 5 8 5 L20 5 C21.7 5 23 6.3 23 8 L23 17 C23 18.7 21.7 20 20 20 L12 20 L7 24 L7 20 L8 20 C6.3 20 5 18.7 5 17 Z"
            stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" fill="currentColor" fill-opacity="0.1" />
          <circle cx="11" cy="12.5" r="1.1" fill="currentColor" />
          <circle cx="14" cy="12.5" r="1.1" fill="currentColor" />
          <circle cx="17" cy="12.5" r="1.1" fill="currentColor" />
        </svg>
      </div>
      <div class="pillars__banner-text">
        <strong>{c.pillars.banner.title}</strong>
        <span>{c.pillars.banner.desc}</span>
      </div>
      <a class="pillars__banner-cta" href="#contato">
        <span>{c.pillars.banner.cta}</span>
        <svg viewBox="0 0 12 12" fill="none" aria-hidden="true">
          <path d="M2 10 L10 2 M4 2 L10 2 L10 8" stroke="currentColor" stroke-width="1.6" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .pillars {
    position: relative;
    overflow: clip;
  }
  .pillars > .container {
    position: relative;
    z-index: 1;
  }
  .pillars__head {
    text-align: center;
    margin-bottom: 64px;
    position: relative;
  }
  .pillars__title {
    margin: 0 auto 20px;
    max-width: 26ch;
  }
  .pillars__intro {
    max-width: 50ch;
    margin: 0 auto;
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  /* ---------------- Grid ---------------- */
  .pillars__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* ---------------- Card ---------------- */
  .pillar {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: 32px;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.45s var(--ease), transform 0.45s var(--ease), box-shadow 0.45s var(--ease);
    display: flex;
    flex-direction: column;
    gap: 12px;
    position: relative;
  }
  .pillar:hover {
    border-color: var(--color-primary-soft);
    transform: translateY(-6px);
    box-shadow: var(--shadow-md);
  }
  .pillar.featured {
    border-color: var(--color-primary);
    background: var(--color-bg-elevated);
    box-shadow: var(--shadow-md);
  }
  .pillar.featured:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
  }

  .pillar__num {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--color-primary);
    letter-spacing: 0.05em;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .pillar__icon-box {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    background: var(--color-primary-pale);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
  }
  .pillar__icon {
    width: 28px;
    height: 28px;
  }
  .pillar__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .pillar__title {
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
    color: var(--color-text);
  }
  .pillar__desc {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    line-height: 1.55;
    margin: 0;
    text-wrap: pretty;
  }

  .pillar__divider {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 6px 0 4px;
    width: 100%;
  }

  .pillar__bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .pillar__bullets li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }
  .pillar__check {
    width: 18px;
    height: 18px;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .pillar__cta {
    margin-top: 16px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: var(--fs-small);
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    transition: gap 0.3s var(--ease), color 0.3s;
  }
  .pillar__cta svg {
    width: 12px;
    height: 12px;
    transition: transform 0.3s var(--ease);
  }
  .pillar:hover .pillar__cta {
    gap: 12px;
  }
  .pillar:hover .pillar__cta svg {
    transform: translate(2px, -2px);
  }

  /* ---------------- Banner CTA ---------------- */
  .pillars__banner {
    margin-top: 32px;
    background: var(--color-bg-deep);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    padding: 20px 28px;
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .pillars__banner-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--color-bg-elevated);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 12px -4px rgba(37, 99, 235, 0.2);
  }
  .pillars__banner-icon svg {
    width: 24px;
    height: 24px;
  }
  .pillars__banner-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .pillars__banner-text strong {
    font-size: var(--fs-body);
    font-weight: 600;
    color: var(--color-text);
  }
  .pillars__banner-text span {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
  }
  .pillars__banner-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-primary);
    color: #fff;
    padding: 12px 22px;
    border-radius: var(--radius-md);
    font-size: var(--fs-small);
    font-weight: 600;
    text-decoration: none;
    transition: background 0.3s var(--ease), transform 0.3s var(--ease), gap 0.3s var(--ease);
    flex-shrink: 0;
  }
  .pillars__banner-cta:hover {
    background: var(--color-primary-bright);
    gap: 12px;
  }
  .pillars__banner-cta svg {
    width: 12px;
    height: 12px;
    transition: transform 0.3s var(--ease);
  }
  .pillars__banner-cta:hover svg {
    transform: translate(2px, -2px);
  }

  /* ---------------- Responsivo ---------------- */
  @media (max-width: 1100px) {
    .pillars__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 720px) {
    .pillars__banner {
      flex-direction: column;
      align-items: stretch;
      text-align: center;
      padding: 24px;
    }
    .pillars__banner-icon {
      margin: 0 auto;
    }
    .pillars__banner-cta {
      justify-content: center;
    }
  }
  @media (max-width: 600px) {
    .pillars__grid {
      grid-template-columns: 1fr;
    }
    .pillar {
      padding: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pillar:hover {
      transform: none;
    }
  }
</style>
