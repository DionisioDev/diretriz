---
import { getContent, type Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const c = getContent(locale);
---

<section class="section-pad section-tint" id="servicos" data-screen-label="03 Pilares">
  <div class="container">
    <div class="pillars__head">
      <div class="section-label center reveal reveal-fade">{c.pillars.label}</div>
      <h2 class="pillars__title reveal reveal-up reveal-d1">
        {c.pillars.titleStart}<span class="blue">{c.pillars.titleAccent}</span>{c.pillars.titleEnd}
      </h2>
      <p class="pillars__intro reveal reveal-up reveal-d2">{c.pillars.intro}</p>
    </div>

    <div class="pillars__grid">
      {c.pillars.items.map((p, i) => (
        <article class:list={['pillar', 'reveal', 'reveal-up', `reveal-d${i + 1}`, p.featured && 'featured']}>
          <div class="pillar__icon">
            {p.num === '01' && (
              <svg viewBox="0 0 36 36" fill="none" stroke="currentColor" stroke-width="1.4">
                <path d="M18 4 L31 11 L31 25 L18 32 L5 25 L5 11 Z" />
                <path d="M18 4 L18 18 L5 11" />
                <path d="M18 18 L31 11" />
                <path d="M18 18 L18 32" />
              </svg>
            )}
            {p.num === '02' && (
              <svg viewBox="0 0 36 36" fill="none" stroke="currentColor" stroke-width="1.4">
                <path d="M6 12 L26 12 L23 8 M30 24 L10 24 L13 28" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            )}
            {p.num === '03' && (
              <svg viewBox="0 0 36 36" fill="none" stroke="currentColor" stroke-width="1.4">
                <path d="M12 6 C8 6 6 9 6 13 C6 15 7 17 8 18 C7 19 7 21 7 22 C7 26 10 29 14 29 L22 29 C26 29 29 26 29 22 C29 21 29 19 28 18 C29 17 30 15 30 13 C30 9 28 6 24 6 C22 6 21 7 20 8 C19 7 17 6 16 6 C14 6 13 6 12 6 Z" />
                <circle cx="14" cy="16" r="1" fill="currentColor" />
                <circle cx="22" cy="16" r="1" fill="currentColor" />
              </svg>
            )}
            {p.num === '04' && (
              <svg viewBox="0 0 36 36" fill="none" stroke="currentColor" stroke-width="1.4">
                <circle cx="13" cy="13" r="4" />
                <circle cx="25" cy="13" r="4" />
                <path d="M5 28 C5 23 9 20 13 20 C17 20 21 23 21 28" />
                <path d="M17 28 C17 23 21 20 25 20 C29 20 33 23 33 28" />
              </svg>
            )}
          </div>
          <div class="pillar__num">{p.num}</div>
          <h3 class="pillar__title">{p.title}</h3>
          <p class="pillar__desc">{p.desc}</p>
          <div class="pillar__arrow">
            <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              <path d="M2 10 L10 2 M4 2 L10 2 L10 8" stroke="currentColor" stroke-width="1.5" fill="none" />
            </svg>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .pillars__head {
    text-align: center;
    margin-bottom: 64px;
  }
  .pillars__title {
    font-size: var(--fs-h2);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.05;
    margin: 0 auto 20px;
    max-width: 22ch;
    text-wrap: balance;
  }
  .pillars__title .blue {
    color: var(--color-primary);
  }
  .pillars__intro {
    max-width: 50ch;
    margin: 0 auto;
    color: var(--color-text-muted);
    text-wrap: pretty;
  }

  .pillars__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .pillar {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 28px;
    transition: border-color 0.4s var(--ease), transform 0.4s var(--ease), box-shadow 0.4s var(--ease);
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    cursor: pointer;
  }
  .pillar:hover {
    border-color: var(--color-primary-soft);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(37, 99, 235, 0.25);
  }
  .pillar.featured {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary), 0 16px 36px -16px rgba(37, 99, 235, 0.3);
  }

  .pillar__icon {
    width: 36px;
    height: 36px;
    color: var(--color-primary);
    margin-bottom: 16px;
  }
  .pillar__num {
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    color: var(--color-text-dim);
    letter-spacing: 0.05em;
    font-weight: 500;
  }
  .pillar__title {
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.2;
    margin: 0;
    color: var(--color-text);
  }
  .pillar__desc {
    font-size: var(--fs-small);
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
    text-wrap: pretty;
    flex: 1;
  }
  .pillar__arrow {
    margin-top: 16px;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border-strong);
    color: var(--color-text-muted);
    transition: background 0.3s, color 0.3s, border-color 0.3s;
  }
  .pillar:hover .pillar__arrow {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }

  @media (max-width: 1100px) {
    .pillars__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .pillars__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
