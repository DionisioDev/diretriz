---
import { getContent, getSectionAnchor, type Locale } from '../../lib/i18n';
import HeroIntro from '../react/HeroIntro/HeroIntro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const c = getContent(locale);

const contactHref = getSectionAnchor('contato', locale);
const aboutHref = getSectionAnchor('sobre', locale);
const taglineFlat = c.hero.tagline.join(' ');
---

<section class="hero" data-screen-label="01 Hero">
  <!-- SEO + screen-readers: tagline completa visível para crawlers -->
  <h1 class="sr-only">{taglineFlat}</h1>

  <div class="container hero__inner">
    <HeroIntro
      client:only="react"
      tagline={c.hero.tagline}
      kicker={c.hero.kicker}
      sub={c.hero.sub}
      ctaPrimary={c.hero.ctaPrimary}
      ctaSecondary={c.hero.ctaSecondary}
      contactHref={contactHref}
      aboutHref={aboutHref}
      preloaderBrand={c.preloader.brand}
    />
    <div class="hero__visual" aria-hidden="true"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    padding-top: 100px;
    padding-bottom: 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    background:
      radial-gradient(ellipse 80% 60% at 80% 30%, rgba(96, 165, 250, 0.18), transparent 60%),
      radial-gradient(ellipse 60% 50% at 20% 80%, rgba(219, 234, 254, 0.6), transparent 60%),
      var(--color-bg);
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: 64px;
    align-items: center;
  }

  .hero__visual {
    position: relative;
    min-height: 540px;
  }

  @media (max-width: 980px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .hero__visual {
      height: 320px;
      order: -1;
    }
  }
</style>
