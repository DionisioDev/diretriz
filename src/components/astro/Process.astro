---
import { getContent, type Locale } from '../../lib/i18n';
import { sectionIcons } from '../../lib/icons';
import SectionBadge from './SectionBadge.astro';
import SectionDecor from './SectionDecor.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const c = getContent(locale);
---

<section class="section-pad process" id="processo" data-screen-label="05 Processo">
  <SectionDecor variant={4} />

  <div class="container">
    <div class="process__head">
      <SectionBadge
        label={c.process.label}
        icon={sectionIcons.process}
        class="reveal reveal-fade"
      />
      <h2 class="section-title process__title reveal reveal-up reveal-d1">
        {c.process.titleStart}<span class="blue">{c.process.titleAccent}</span>
      </h2>
    </div>

    <ol class="process__chevrons" aria-label={c.process.label}>
      {c.process.steps.map((s, i) => (
        <li class:list={['chevron', `chevron--${i + 1}`, 'reveal', 'reveal-stagger', `reveal-d${i + 1}`, i === c.process.steps.length - 1 && 'chevron--last']}>
          <div class="chevron__inner">
            <div class="chevron__icon" aria-hidden="true">
              {s.n === '01' && (
                <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
                  <path d="M5 8 C5 6.3 6.3 5 8 5 L20 5 C21.7 5 23 6.3 23 8 L23 17 C23 18.7 21.7 20 20 20 L12 20 L7 24 L7 20 L8 20 C6.3 20 5 18.7 5 17 Z" />
                </svg>
              )}
              {s.n === '02' && (
                <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="14" cy="14" r="10" />
                  <circle cx="14" cy="14" r="6" />
                  <circle cx="14" cy="14" r="2.5" fill="currentColor" stroke="none" />
                </svg>
              )}
              {s.n === '03' && (
                <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10 9 L4 14 L10 19" />
                  <path d="M18 9 L24 14 L18 19" />
                  <path d="M16 6 L12 22" />
                </svg>
              )}
              {s.n === '04' && (
                <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round">
                  <path d="M19 4 C16 6 13 9 11 13 L8 13 L5 17 L9 18 L10 22 L14 19 L14 16 C18 14 21 11 23 8 C24 6 24 5 24 4 C23 4 21 4 19 4 Z" />
                  <circle cx="18" cy="10" r="1.4" fill="currentColor" stroke="none" />
                  <path d="M11 18 L8 21 M9 22 L7 24" />
                </svg>
              )}
              {s.n === '05' && (
                <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round">
                  <path d="M5 22 L5 14" stroke-linecap="round" />
                  <path d="M12 22 L12 9" stroke-linecap="round" />
                  <path d="M19 22 L19 5" stroke-linecap="round" />
                  <path d="M3 22 L23 22" stroke-linecap="round" />
                </svg>
              )}
            </div>
            <div class="chevron__num">{s.n}</div>
            <h3 class="chevron__title">{s.title}</h3>
            <p class="chevron__desc">{s.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .process {
    position: relative;
    overflow: clip;
  }
  .process > .container {
    position: relative;
    z-index: 1;
  }
  .process__head {
    margin-bottom: 56px;
  }
  .process__title {
    margin: 0;
    max-width: 18ch;
  }

  /* ---------------- Chevrons ---------------- */
  .process__chevrons {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: stretch;
    width: 100%;
  }

  .chevron {
    flex: 1 1 0;
    min-width: 0;
    position: relative;
    color: var(--color-text);
    /* clip-path: ponta direita + entalhe esquerdo, ambos com 26px de "profundidade" */
    clip-path: polygon(
      0% 0%,
      calc(100% - 26px) 0%,
      100% 50%,
      calc(100% - 26px) 100%,
      0% 100%,
      26px 50%
    );
  }
  .chevron + .chevron {
    margin-left: -26px; /* encaixa a ponta do anterior no entalhe deste */
  }

  /* Gradiente progressivo de fundo: claro → azul saturado */
  .chevron--1 { background: #EEF4FC; }
  .chevron--2 { background: #DDE8F8; }
  .chevron--3 { background: #C7D8F2; }
  .chevron--4 { background: #A9C2EB; }
  .chevron--5 {
    background: var(--color-primary);
    color: var(--color-text-on-dark);
  }

  .chevron__inner {
    padding: 28px 24px 28px 38px; /* padding-left maior pra compensar o entalhe */
    display: flex;
    flex-direction: column;
    gap: 8px;
    height: 100%;
  }
  /* primeiro chevron: padding-left normal, sem entalhe visualmente */
  .chevron--1 .chevron__inner {
    padding-left: 24px;
  }
  /* último chevron: padding-right maior pra dar respiro até a ponta */
  .chevron--last .chevron__inner {
    padding-right: 38px;
  }

  .chevron__icon {
    width: 28px;
    height: 28px;
    color: var(--color-primary);
    margin-bottom: 6px;
  }
  .chevron--last .chevron__icon {
    color: var(--color-text-on-dark);
  }
  .chevron__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .chevron__num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-primary);
    letter-spacing: 0.05em;
    font-weight: 600;
    opacity: 0.85;
  }
  .chevron--last .chevron__num {
    color: var(--color-text-on-dark);
    opacity: 0.9;
  }

  .chevron__title {
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.2;
    margin: 0;
    color: inherit;
  }

  .chevron__desc {
    font-size: 0.8125rem;
    line-height: 1.45;
    margin: 0;
    color: var(--color-text-muted);
    text-wrap: pretty;
  }
  .chevron--last .chevron__desc {
    color: rgba(255, 255, 255, 0.85);
  }

  /* primeiro chevron: clip-path sem entalhe esquerdo, mantém ponta direita */
  .chevron--1 {
    clip-path: polygon(
      0% 0%,
      calc(100% - 26px) 0%,
      100% 50%,
      calc(100% - 26px) 100%,
      0% 100%
    );
  }

  /* ---------------- Responsivo ---------------- */
  @media (max-width: 1100px) {
    .chevron__inner {
      padding: 22px 18px 22px 32px;
    }
    .chevron--1 .chevron__inner {
      padding-left: 18px;
    }
    .chevron__title {
      font-size: 1rem;
    }
    .chevron__desc {
      font-size: 0.75rem;
    }
  }

  @media (max-width: 900px) {
    .process__chevrons {
      flex-direction: column;
      gap: 12px;
    }
    .chevron,
    .chevron--1 {
      flex: none;
      clip-path: none;
      border-radius: var(--radius-lg);
    }
    .chevron + .chevron {
      margin-left: 0;
    }
    .chevron__inner,
    .chevron--1 .chevron__inner,
    .chevron--last .chevron__inner {
      padding: 22px 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .chevron {
      transition: none;
    }
  }
</style>
