---
import BrandMark from './BrandMark.astro';
import { getContent, type Locale } from '../../lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as Props;
const c = getContent(locale);
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__card">
    <div class="footer__top">
      <div class="footer__brand-col">
        <a href={locale === 'pt' ? '/' : '/en/'} class="footer__brand" aria-label="Diretriz Tecnologia">
          <BrandMark size={30} />
          <span class="footer__brand-text">
            <span class="footer__brand-name">Diretriz</span>
            <small>tecnologia</small>
          </span>
        </a>
        <p>{c.footer.tagline}</p>
      </div>

      {c.footer.cols.map((col) => (
        <div class="footer__col">
          <h4>{col.title}</h4>
          <ul>
            {col.links.map((l) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="footer__bottom">
      <span>© {year} Diretriz Tecnologia. {c.footer.rights}</span>
      <span>{c.footer.privacy}</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: clamp(40px, 6vw, 72px) 0 clamp(24px, 4vw, 40px);
    border-top: 1px solid var(--color-border);
    background: linear-gradient(180deg, #eef3fb 0%, #e3ebf7 100%);
  }

  /* Mesmo padrão de "card flutuante" do header: largura contida com gutters,
     cantos arredondados (--radius-2xl), borda sutil e sombra. */
  .footer__card {
    width: min(calc(100% - var(--gutter) * 2), var(--container-max));
    margin-inline: auto;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-sm);
    padding: clamp(36px, 4.5vw, 56px) clamp(28px, 4vw, 48px) clamp(24px, 3vw, 32px);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr 1fr;
    gap: 32px;
    margin-bottom: 40px;
    align-items: start;
  }

  /* Divisor vertical após a marca — eco do divisor do header. */
  .footer__brand-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-self: stretch;
    padding-right: clamp(20px, 2.5vw, 36px);
    border-right: 1px solid var(--color-border);
  }
  .footer__brand-col p {
    color: var(--color-text-muted);
    font-size: var(--fs-small);
    margin: 0;
    max-width: 28ch;
  }

  .footer__brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--color-text);
  }
  .footer__brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .footer__brand-name {
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.015em;
  }
  .footer__brand small {
    font-size: 0.66rem;
    color: var(--color-primary);
    font-weight: 500;
    letter-spacing: 0.04em;
    margin-top: 3px;
  }

  .footer__col h4 {
    margin: 0 0 14px 0;
    font-family: var(--font-mono);
    font-size: var(--fs-mono);
    color: var(--color-text-dim);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .footer__col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 8px;
  }
  .footer__col a {
    display: inline-block;
    color: var(--color-text-muted);
    font-size: var(--fs-small);
    transition: color 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .footer__col a:hover {
    color: var(--color-primary);
    transform: translateX(3px);
  }

  .footer__bottom {
    border-top: 1px solid var(--color-border);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    font-size: var(--fs-xs);
    color: var(--color-text-dim);
  }
  .footer__bottom a,
  .footer__bottom span:last-child {
    transition: color 0.25s var(--ease);
  }

  @media (max-width: 880px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
    }
    .footer__brand-col {
      grid-column: 1 / -1;
      align-self: auto;
      padding-right: 0;
      border-right: none;
      padding-bottom: 24px;
      border-bottom: 1px solid var(--color-border);
    }
  }
</style>
