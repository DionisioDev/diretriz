  </defs>
  <path d="M2 18 L18 13 L9 26 Z" fill="url(#bm-back)" />
  <path d="M9 26 L4 22 L7 26 Z" fill="#334155" />
  <path d="M8 4 L30 12 L22 14 L14 18 Z" fill="url(#bm-front)" />
