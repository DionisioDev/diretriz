---
/**
 * BrandMark — logo oficial da Diretriz (avião de papel).
 * Usa o asset real (public/assets/logo-mark.png), não um SVG aproximado.
 */
interface Props {
  size?: number;
}
const { size = 22 } = Astro.props as Props;
const width = Math.round((size * 100) / 96); // proporção real do asset (100×96)
---

<img
  src="/assets/logo-mark.png"
  width={width}
  height={size}
  alt=""
  class="brand-mark"
  decoding="async"
/>

<style>
  .brand-mark {
    display: block;
    flex-shrink: 0;
  }
</style>
