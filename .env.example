# ============================================================
# Variáveis do site Diretriz
# ============================================================
#
# 1) CLIENT (prefixo PUBLIC_, expostas no browser) — usadas pelo build do Astro.
#    Renomeie este arquivo para `.env` para uso local.
#
# (EmailJS é OPCIONAL — o formulário hoje envia pela Pages Function /api/contact
#  via Resend. Mantido aqui apenas se quiser voltar ao fluxo client-side.)
PUBLIC_EMAILJS_SERVICE_ID=
PUBLIC_EMAILJS_TEMPLATE_ID=
PUBLIC_EMAILJS_PUBLIC_KEY=

# ============================================================
# 2) SERVIDOR (Pages Functions) — NÃO vão no .env do build estático.
#    Configure no painel Cloudflare Pages → Settings → Environment variables,
#    e o binding de IA em Settings → Functions → AI bindings.
#    Passo a passo em docs/chat-setup.md.
# ============================================================
#
#   AI                = binding do Workers AI (nome do binding: AI)
#   RESEND_API_KEY    = (secret) chave da conta resend.com
#   LEAD_TO_EMAIL     = diretriztecnologia@gmail.com   (opcional, já é o default)
#   LEAD_FROM_EMAIL   = "Diretriz Site <onboarding@resend.dev>"  (opcional)
